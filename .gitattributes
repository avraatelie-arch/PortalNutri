# =============================================================================
# PortalNutri Platform — Git Attributes
# =============================================================================

# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# -----------------------------------------------------------------------------
# Source code
# -----------------------------------------------------------------------------
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf

# -----------------------------------------------------------------------------
# Markup, styling and configuration
# -----------------------------------------------------------------------------
*.json      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf
*.xml       text eol=lf
*.svg       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.editorconfig text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
*.md        text eol=lf
*.mdc       text eol=lf
*.txt       text eol=lf

# -----------------------------------------------------------------------------
# Database and infrastructure
# -----------------------------------------------------------------------------
*.prisma    text eol=lf
*.sql       text eol=lf
Dockerfile  text eol=lf
*.dockerfile text eol=lf
*.sh        text eol=lf
*.bash      text eol=lf
*.ps1       text eol=lf

# -----------------------------------------------------------------------------
# Binary files — do not modify line endings
# -----------------------------------------------------------------------------
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.bmp   binary
*.tiff  binary
*.tif   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.7z    binary
*.rar   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
*.exe   binary
*.dll   binary
*.so    binary
*.dylib binary
