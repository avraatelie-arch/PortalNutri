# =============================================================================
# PortalNutri Platform — Root .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# pnpm
# -----------------------------------------------------------------------------
.pnpm-store/
.pnpm-debug.log*
.pnp
.pnp.*

# -----------------------------------------------------------------------------
# NestJS / TypeScript build output
# -----------------------------------------------------------------------------
dist/
build/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
.next/
out/
next-env.d.ts
.vercel

# -----------------------------------------------------------------------------
# Prisma
# -----------------------------------------------------------------------------
prisma/*.db
prisma/*.db-journal

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# -----------------------------------------------------------------------------
# Environment variables (contains sensitive secrets)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# -----------------------------------------------------------------------------
# Cursor — local IDE state (preserves .cursor/rules/)
# -----------------------------------------------------------------------------
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# -----------------------------------------------------------------------------
# Other IDEs and editors
# -----------------------------------------------------------------------------
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Linux
# -----------------------------------------------------------------------------
*~

# -----------------------------------------------------------------------------
# Certificates and keys
# -----------------------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.cache
.cache/
