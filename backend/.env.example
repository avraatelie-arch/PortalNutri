PORT=3333
NODE_ENV=development
HOST=0.0.0.0
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portalnutri?schema=public"
CORS_ORIGIN=*

# OpenAPI docs at /docs and /docs/json.
# Enabled by default outside production; disabled by default in production when omitted.
# Set OPENAPI_ENABLED=true or OPENAPI_ENABLED=false to override explicitly.
OPENAPI_ENABLED=true

# Logging (Pino via Fastify).
# LOG_LEVEL defaults to info. LOG_PRETTY defaults to true in development and false elsewhere.
# Pretty logs are only enabled in development; production always uses JSON logs.
LOG_LEVEL=info
LOG_PRETTY=true
