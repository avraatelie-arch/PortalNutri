datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum PersonStatus {
  ACTIVE
  INACTIVE
}

enum DocumentType {
  CPF
  RG
  CNH
  PASSPORT
  OTHER
}

model Person {
  id            String       @id @default(uuid())
  fullName      String       @map("full_name")
  preferredName String?      @map("preferred_name")
  email         String       @unique
  phone         String?
  document      String
  documentType  DocumentType @map("document_type")
  birthDate     DateTime     @map("birth_date") @db.Date
  status        PersonStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  credential    Credential?
  sessions      Session[]
  memberships   Membership[]
  nutritionists Nutritionist[]

  @@unique([documentType, document])
  @@map("persons")
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model Session {
  id                    String        @id @default(uuid())
  personId              String        @map("person_id")
  tenantId              String?       @map("tenant_id")
  status                SessionStatus @default(ACTIVE)
  refreshTokenHash      String        @unique @map("refresh_token_hash")
  refreshTokenFamilyId  String        @map("refresh_token_family_id")
  refreshTokenExpiresAt DateTime      @map("refresh_token_expires_at")
  expiresAt             DateTime      @map("expires_at")
  lastAccessAt          DateTime      @map("last_access_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  revokedAt             DateTime?     @map("revoked_at")
  person                Person        @relation(fields: [personId], references: [id], onDelete: Restrict)

  @@index([personId])
  @@index([refreshTokenFamilyId])
  @@map("sessions")
}

enum CredentialStatus {
  ACTIVE
  LOCKED
  DISABLED
  EXPIRED
}

model Credential {
  id           String           @id @default(uuid())
  personId     String           @unique @map("person_id")
  passwordHash String           @map("password_hash")
  status       CredentialStatus @default(ACTIVE)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  person       Person           @relation(fields: [personId], references: [id], onDelete: Restrict)

  @@map("credentials")
}

enum PermissionAssignmentStatus {
  ACTIVE
  REMOVED
}

model Permission {
  id                    String                 @id @default(uuid())
  tenantId              String                 @map("tenant_id")
  name                  String
  normalizedName        String                 @map("normalized_name")
  createdAt             DateTime               @default(now()) @map("created_at")
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  permissionAssignments PermissionAssignment[]

  @@unique([tenantId, normalizedName])
  @@index([tenantId])
  @@map("permissions")
}

model PermissionAssignment {
  id            String                     @id @default(uuid())
  roleId        String                     @map("role_id")
  permissionId  String                     @map("permission_id")
  status        PermissionAssignmentStatus @default(ACTIVE)
  createdAt     DateTime                   @default(now()) @map("created_at")
  reactivatedAt DateTime?                  @map("reactivated_at")
  removedAt     DateTime?                  @map("removed_at")
  role          Role                       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission    Permission                 @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("permission_assignments")
}

model Role {
  id                    String                 @id @default(uuid())
  tenantId              String                 @map("tenant_id")
  name                  String
  normalizedName        String                 @map("normalized_name")
  createdAt             DateTime               @default(now()) @map("created_at")
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  roleAssignments       RoleAssignment[]
  permissionAssignments PermissionAssignment[]

  @@unique([tenantId, normalizedName])
  @@index([tenantId])
  @@map("roles")
}

enum RoleAssignmentStatus {
  ACTIVE
  REMOVED
}

model RoleAssignment {
  id            String               @id @default(uuid())
  membershipId  String               @map("membership_id")
  roleId        String               @map("role_id")
  status        RoleAssignmentStatus @default(ACTIVE)
  createdAt     DateTime             @default(now()) @map("created_at")
  reactivatedAt DateTime?            @map("reactivated_at")
  removedAt     DateTime?            @map("removed_at")
  membership    Membership           @relation(fields: [membershipId], references: [id], onDelete: Restrict)
  role          Role                 @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([membershipId, roleId])
  @@index([membershipId])
  @@index([roleId])
  @@map("role_assignments")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

model Tenant {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  status      TenantStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  memberships   Membership[]
  roles         Role[]
  permissions   Permission[]
  nutritionists Nutritionist[]

  @@map("tenants")
}

enum MembershipStatus {
  ACTIVE
  REMOVED
}

model Membership {
  id            String           @id @default(uuid())
  personId      String           @map("person_id")
  tenantId      String           @map("tenant_id")
  status        MembershipStatus @default(ACTIVE)
  createdAt     DateTime         @default(now()) @map("created_at")
  reactivatedAt DateTime?        @map("reactivated_at")
  removedAt     DateTime?        @map("removed_at")
  person          Person           @relation(fields: [personId], references: [id], onDelete: Restrict)
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  roleAssignments RoleAssignment[]

  @@unique([personId, tenantId])
  @@index([personId])
  @@index([tenantId])
  @@map("memberships")
}

enum NutritionistStatus {
  ACTIVE
  INACTIVE
}

model Nutritionist {
  id        String             @id @default(uuid())
  personId  String             @map("person_id")
  tenantId  String             @map("tenant_id")
  crn       String
  state     String             @db.Char(2)
  specialty String
  bio       String?
  status    NutritionistStatus @default(ACTIVE)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  person    Person             @relation(fields: [personId], references: [id], onDelete: Restrict)
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, crn])
  @@index([personId])
  @@index([tenantId])
  @@map("nutritionists")
}
