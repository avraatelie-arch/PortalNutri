datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum PersonStatus {
  ACTIVE
  INACTIVE
}

enum DocumentType {
  CPF
  RG
  CNH
  PASSPORT
  OTHER
}

model Person {
  id            String       @id @default(uuid())
  fullName      String       @map("full_name")
  preferredName String?      @map("preferred_name")
  email         String       @unique
  phone         String?
  document      String
  documentType  DocumentType @map("document_type")
  birthDate     DateTime     @map("birth_date") @db.Date
  status        PersonStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  credential    Credential?
  sessions      Session[]
  memberships   Membership[]
  nutritionists Nutritionist[]

  @@unique([documentType, document])
  @@map("persons")
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model Session {
  id                    String        @id @default(uuid())
  personId              String        @map("person_id")
  tenantId              String?       @map("tenant_id")
  status                SessionStatus @default(ACTIVE)
  refreshTokenHash      String        @unique @map("refresh_token_hash")
  refreshTokenFamilyId  String        @map("refresh_token_family_id")
  refreshTokenExpiresAt DateTime      @map("refresh_token_expires_at")
  expiresAt             DateTime      @map("expires_at")
  lastAccessAt          DateTime      @map("last_access_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  revokedAt             DateTime?     @map("revoked_at")
  person                Person        @relation(fields: [personId], references: [id], onDelete: Restrict)

  @@index([personId])
  @@index([refreshTokenFamilyId])
  @@map("sessions")
}

enum CredentialStatus {
  ACTIVE
  LOCKED
  DISABLED
  EXPIRED
}

model Credential {
  id           String           @id @default(uuid())
  personId     String           @unique @map("person_id")
  passwordHash String           @map("password_hash")
  status       CredentialStatus @default(ACTIVE)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  person       Person           @relation(fields: [personId], references: [id], onDelete: Restrict)

  @@map("credentials")
}

enum PermissionAssignmentStatus {
  ACTIVE
  REMOVED
}

model Permission {
  id                    String                 @id @default(uuid())
  tenantId              String                 @map("tenant_id")
  name                  String
  normalizedName        String                 @map("normalized_name")
  createdAt             DateTime               @default(now()) @map("created_at")
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  permissionAssignments PermissionAssignment[]

  @@unique([tenantId, normalizedName])
  @@index([tenantId])
  @@map("permissions")
}

model PermissionAssignment {
  id            String                     @id @default(uuid())
  roleId        String                     @map("role_id")
  permissionId  String                     @map("permission_id")
  status        PermissionAssignmentStatus @default(ACTIVE)
  createdAt     DateTime                   @default(now()) @map("created_at")
  reactivatedAt DateTime?                  @map("reactivated_at")
  removedAt     DateTime?                  @map("removed_at")
  role          Role                       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission    Permission                 @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("permission_assignments")
}

model Role {
  id                    String                 @id @default(uuid())
  tenantId              String                 @map("tenant_id")
  name                  String
  normalizedName        String                 @map("normalized_name")
  createdAt             DateTime               @default(now()) @map("created_at")
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  roleAssignments       RoleAssignment[]
  permissionAssignments PermissionAssignment[]

  @@unique([tenantId, normalizedName])
  @@index([tenantId])
  @@map("roles")
}

enum RoleAssignmentStatus {
  ACTIVE
  REMOVED
}

model RoleAssignment {
  id            String               @id @default(uuid())
  membershipId  String               @map("membership_id")
  roleId        String               @map("role_id")
  status        RoleAssignmentStatus @default(ACTIVE)
  createdAt     DateTime             @default(now()) @map("created_at")
  reactivatedAt DateTime?            @map("reactivated_at")
  removedAt     DateTime?            @map("removed_at")
  membership    Membership           @relation(fields: [membershipId], references: [id], onDelete: Restrict)
  role          Role                 @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([membershipId, roleId])
  @@index([membershipId])
  @@index([roleId])
  @@map("role_assignments")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

model Tenant {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  status      TenantStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  memberships   Membership[]
  roles         Role[]
  permissions   Permission[]
  nutritionists Nutritionist[]
  patients      Patient[]
  patientNutritionistAssignments PatientNutritionistAssignment[]
  appointments                   Appointment[]
  clinicalEncounters             ClinicalEncounter[]
  anamneses                      Anamnesis[]
  anthropometricAssessments      AnthropometricAssessment[]
  bodyCompositionAssessments     BodyCompositionAssessment[]
  clinicalObjectives             ClinicalObjective[]

  @@map("tenants")
}

enum MembershipStatus {
  ACTIVE
  REMOVED
}

model Membership {
  id            String           @id @default(uuid())
  personId      String           @map("person_id")
  tenantId      String           @map("tenant_id")
  status        MembershipStatus @default(ACTIVE)
  createdAt     DateTime         @default(now()) @map("created_at")
  reactivatedAt DateTime?        @map("reactivated_at")
  removedAt     DateTime?        @map("removed_at")
  person          Person           @relation(fields: [personId], references: [id], onDelete: Restrict)
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  roleAssignments RoleAssignment[]

  @@unique([personId, tenantId])
  @@index([personId])
  @@index([tenantId])
  @@map("memberships")
}

enum NutritionistStatus {
  ACTIVE
  INACTIVE
}

model Nutritionist {
  id        String             @id @default(uuid())
  personId  String             @map("person_id")
  tenantId  String             @map("tenant_id")
  crn       String
  state     String             @db.Char(2)
  specialty String
  bio       String?
  status    NutritionistStatus @default(ACTIVE)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  person    Person             @relation(fields: [personId], references: [id], onDelete: Restrict)
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  patientAssignments PatientNutritionistAssignment[]
  appointments       Appointment[]
  clinicalEncounters        ClinicalEncounter[]
  anamneses                 Anamnesis[]
  anthropometricAssessments AnthropometricAssessment[]
  bodyCompositionAssessments BodyCompositionAssessment[]
  clinicalObjectivesCreated     ClinicalObjective[] @relation("ClinicalObjectiveCreatedBy")
  clinicalObjectivesResponsible ClinicalObjective[] @relation("ClinicalObjectiveResponsible")

  @@unique([tenantId, crn])
  @@index([personId])
  @@index([tenantId])
  @@map("nutritionists")
}

enum PatientStatus {
  ACTIVE
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
  OTHER
  NOT_INFORMED
}

model Patient {
  id        String        @id @default(uuid())
  tenantId  String        @map("tenant_id")
  fullName  String        @map("full_name")
  birthDate DateTime      @map("birth_date") @db.Date
  gender    Gender
  phone     String?
  email     String?
  status    PatientStatus @default(ACTIVE)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  nutritionistAssignments PatientNutritionistAssignment[]
  appointments            Appointment[]
  clinicalEncounters        ClinicalEncounter[]
  anamneses                 Anamnesis[]
  anthropometricAssessments AnthropometricAssessment[]
  bodyCompositionAssessments BodyCompositionAssessment[]
  clinicalObjectives         ClinicalObjective[]

  @@index([tenantId])
  @@map("patients")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentMode {
  IN_PERSON
  ONLINE
}

model Appointment {
  id                 String            @id @default(uuid())
  tenantId           String            @map("tenant_id")
  patientId          String            @map("patient_id")
  nutritionistId     String            @map("nutritionist_id")
  startsAt           DateTime          @map("starts_at")
  endsAt             DateTime          @map("ends_at")
  mode               AppointmentMode
  status             AppointmentStatus @default(SCHEDULED)
  notes              String?
  cancellationReason String?           @map("cancellation_reason")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  cancelledAt        DateTime?         @map("cancelled_at")
  completedAt        DateTime?         @map("completed_at")
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  patient            Patient           @relation(fields: [patientId], references: [id], onDelete: Restrict)
  nutritionist       Nutritionist      @relation(fields: [nutritionistId], references: [id], onDelete: Restrict)
  clinicalEncounter  ClinicalEncounter?

  @@index([tenantId])
  @@index([patientId])
  @@index([nutritionistId])
  @@index([tenantId, startsAt])
  @@index([nutritionistId, startsAt, endsAt])
  @@index([patientId, startsAt, endsAt])
  @@map("appointments")
}

enum ClinicalEncounterType {
  INITIAL
  FOLLOW_UP
  RETURN
  EMERGENCY
}

enum ClinicalEncounterStatus {
  OPEN
  FINISHED
  CANCELLED
}

model ClinicalEncounter {
  id             String                  @id @default(uuid())
  tenantId       String                  @map("tenant_id")
  appointmentId  String?                 @unique @map("appointment_id")
  patientId      String                  @map("patient_id")
  nutritionistId String                  @map("nutritionist_id")
  type           ClinicalEncounterType
  status         ClinicalEncounterStatus @default(OPEN)
  notes          String?
  startedAt      DateTime                @map("started_at")
  finishedAt     DateTime?               @map("finished_at")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  appointment    Appointment?            @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  patient        Patient                 @relation(fields: [patientId], references: [id], onDelete: Restrict)
  nutritionist   Nutritionist            @relation(fields: [nutritionistId], references: [id], onDelete: Restrict)
  anamnesis                 Anamnesis?
  anthropometricAssessments AnthropometricAssessment[]
  bodyCompositionAssessments BodyCompositionAssessment[]
  originClinicalObjectives ClinicalObjective[] @relation("ClinicalObjectiveOriginEncounter")

  @@index([tenantId])
  @@index([patientId])
  @@index([nutritionistId])
  @@index([tenantId, patientId])
  @@map("clinical_encounters")
}

enum AnamnesisStatus {
  DRAFT
  COMPLETED
}

model Anamnesis {
  id                       String          @id @default(uuid())
  tenantId                 String          @map("tenant_id")
  clinicalEncounterId      String          @unique @map("clinical_encounter_id")
  patientId                String          @map("patient_id")
  nutritionistId           String          @map("nutritionist_id")
  status                   AnamnesisStatus @default(DRAFT)
  version                  Int             @default(1)
  chiefComplaint           String?         @map("chief_complaint") @db.Text
  currentHistory           String?         @map("current_history") @db.Text
  medicalHistory           String?         @map("medical_history") @db.Text
  familyHistory            String?         @map("family_history") @db.Text
  gastrointestinalHistory  String?         @map("gastrointestinal_history") @db.Text
  dietaryHistory           String?         @map("dietary_history") @db.Text
  lifestyleHistory         String?         @map("lifestyle_history") @db.Text
  medicationHistory        String?         @map("medication_history") @db.Text
  supplementHistory        String?         @map("supplement_history") @db.Text
  allergiesAndIntolerances String?         @map("allergies_and_intolerances") @db.Text
  observations             String?         @db.Text
  completedAt              DateTime?       @map("completed_at")
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")
  tenant                   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  clinicalEncounter        ClinicalEncounter @relation(fields: [clinicalEncounterId], references: [id], onDelete: Restrict)
  patient                  Patient           @relation(fields: [patientId], references: [id], onDelete: Restrict)
  nutritionist              Nutritionist                @relation(fields: [nutritionistId], references: [id], onDelete: Restrict)
  anthropometricAssessments AnthropometricAssessment[]
  bodyCompositionAssessments BodyCompositionAssessment[]
  originClinicalObjectives ClinicalObjective[] @relation("ClinicalObjectiveOriginAnamnesis")

  @@index([tenantId])
  @@index([patientId])
  @@index([nutritionistId])
  @@index([tenantId, patientId])
  @@index([tenantId, nutritionistId])
  @@index([tenantId, clinicalEncounterId])
  @@index([status])
  @@map("anamneses")
}

enum BodyMassIndexClassification {
  UNDERWEIGHT
  NORMAL
  OVERWEIGHT
  OBESITY_CLASS_I
  OBESITY_CLASS_II
  OBESITY_CLASS_III
  PEDIATRIC_NOT_SUPPORTED
  UNCLASSIFIED
}

model AnthropometricAssessment {
  id                          String                      @id @default(uuid())
  tenantId                    String                      @map("tenant_id")
  anamnesisId                 String                      @map("anamnesis_id")
  clinicalEncounterId         String                      @map("clinical_encounter_id")
  patientId                   String                      @map("patient_id")
  nutritionistId              String                      @map("nutritionist_id")
  sourceRequestId             String?                     @map("source_request_id")
  weightKg                    Decimal                     @map("weight_kg") @db.Decimal(6, 2)
  heightCm                    Decimal                     @map("height_cm") @db.Decimal(5, 2)
  bodyMassIndex               Decimal                     @map("body_mass_index") @db.Decimal(5, 2)
  bodyMassIndexClassification BodyMassIndexClassification @map("body_mass_index_classification")
  waistCircumferenceCm        Decimal?                    @map("waist_circumference_cm") @db.Decimal(6, 2)
  hipCircumferenceCm          Decimal?                    @map("hip_circumference_cm") @db.Decimal(6, 2)
  abdominalCircumferenceCm    Decimal?                    @map("abdominal_circumference_cm") @db.Decimal(6, 2)
  neckCircumferenceCm         Decimal?                    @map("neck_circumference_cm") @db.Decimal(6, 2)
  armCircumferenceCm          Decimal?                    @map("arm_circumference_cm") @db.Decimal(6, 2)
  calfCircumferenceCm         Decimal?                    @map("calf_circumference_cm") @db.Decimal(6, 2)
  waistToHipRatio             Decimal?                    @map("waist_to_hip_ratio") @db.Decimal(5, 3)
  notes                       String?                     @db.Text
  measuredAt                  DateTime                    @map("measured_at")
  version                     Int                         @default(1)
  createdAt                   DateTime                    @default(now()) @map("created_at")
  tenant                      Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  anamnesis                   Anamnesis                   @relation(fields: [anamnesisId], references: [id], onDelete: Restrict)
  clinicalEncounter           ClinicalEncounter           @relation(fields: [clinicalEncounterId], references: [id], onDelete: Restrict)
  patient                     Patient                     @relation(fields: [patientId], references: [id], onDelete: Restrict)
  nutritionist                Nutritionist                @relation(fields: [nutritionistId], references: [id], onDelete: Restrict)
  bodyCompositionAssessments  BodyCompositionAssessment[]

  @@unique([tenantId, sourceRequestId])
  @@index([tenantId])
  @@index([anamnesisId])
  @@index([patientId])
  @@index([clinicalEncounterId])
  @@index([nutritionistId])
  @@index([tenantId, anamnesisId])
  @@index([tenantId, patientId, measuredAt])
  @@index([tenantId, clinicalEncounterId])
  @@map("anthropometric_assessments")
}

enum BodyCompositionMeasurementSource {
  MANUAL
  BIOIMPEDANCE
  DEXA
  SKINFOLD
  OTHER
}

model BodyCompositionAssessment {
  id                         String                           @id @default(uuid())
  tenantId                   String                           @map("tenant_id")
  anamnesisId                String                           @map("anamnesis_id")
  clinicalEncounterId        String                           @map("clinical_encounter_id")
  patientId                  String                           @map("patient_id")
  nutritionistId             String                           @map("nutritionist_id")
  anthropometricAssessmentId String?                          @map("anthropometric_assessment_id")
  sourceRequestId            String?                          @map("source_request_id")
  bodyFatPercentage          Decimal                          @map("body_fat_percentage") @db.Decimal(5, 2)
  leanMassKg                 Decimal?                         @map("lean_mass_kg") @db.Decimal(6, 2)
  fatMassKg                  Decimal?                         @map("fat_mass_kg") @db.Decimal(6, 2)
  muscleMassKg               Decimal?                         @map("muscle_mass_kg") @db.Decimal(6, 2)
  boneMassKg                 Decimal?                         @map("bone_mass_kg") @db.Decimal(6, 2)
  bodyWaterPercentage        Decimal?                         @map("body_water_percentage") @db.Decimal(5, 2)
  visceralFatLevel           Decimal?                         @map("visceral_fat_level") @db.Decimal(6, 2)
  basalMetabolicRate         Int?                             @map("basal_metabolic_rate")
  metabolicAge               Int?                             @map("metabolic_age")
  notes                      String?                          @db.Text
  measurementSource          BodyCompositionMeasurementSource @map("measurement_source")
  measuredAt                 DateTime                         @map("measured_at")
  version                    Int                              @default(1)
  createdAt                  DateTime                         @default(now()) @map("created_at")
  tenant                     Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  anamnesis                  Anamnesis                        @relation(fields: [anamnesisId], references: [id], onDelete: Restrict)
  clinicalEncounter          ClinicalEncounter                @relation(fields: [clinicalEncounterId], references: [id], onDelete: Restrict)
  patient                    Patient                          @relation(fields: [patientId], references: [id], onDelete: Restrict)
  nutritionist               Nutritionist                     @relation(fields: [nutritionistId], references: [id], onDelete: Restrict)
  anthropometricAssessment   AnthropometricAssessment?        @relation(fields: [anthropometricAssessmentId], references: [id], onDelete: Restrict)

  @@unique([tenantId, sourceRequestId])
  @@index([tenantId])
  @@index([anamnesisId])
  @@index([patientId])
  @@index([clinicalEncounterId])
  @@index([nutritionistId])
  @@index([anthropometricAssessmentId])
  @@index([tenantId, anamnesisId])
  @@index([tenantId, patientId, measuredAt])
  @@index([tenantId, clinicalEncounterId])
  @@map("body_composition_assessments")
}

enum ClinicalObjectiveStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum ClinicalObjectiveType {
  WEIGHT_LOSS
  WEIGHT_GAIN
  MUSCLE_GAIN
  BODY_FAT_REDUCTION
  GLYCEMIC_CONTROL
  LIPID_CONTROL
  BLOOD_PRESSURE_CONTROL
  GASTROINTESTINAL_SYMPTOM_CONTROL
  SPORTS_PERFORMANCE
  PREGNANCY_SUPPORT
  POSTPARTUM_RECOVERY
  EATING_BEHAVIOR
  NUTRITION_EDUCATION
  CLINICAL_CONDITION_SUPPORT
  OTHER
}

enum ClinicalObjectivePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ClinicalObjective {
  id                          String                    @id @default(uuid())
  tenantId                    String                    @map("tenant_id")
  patientId                   String                    @map("patient_id")
  createdByNutritionistId     String                    @map("created_by_nutritionist_id")
  responsibleNutritionistId   String                    @map("responsible_nutritionist_id")
  originClinicalEncounterId   String?                   @map("origin_clinical_encounter_id")
  originAnamnesisId           String?                   @map("origin_anamnesis_id")
  type                        ClinicalObjectiveType
  status                      ClinicalObjectiveStatus   @default(DRAFT)
  priority                    ClinicalObjectivePriority @default(MEDIUM)
  title                       String                    @default("")
  clinicalRationale           String?                   @map("clinical_rationale") @db.Text
  successCriteria             String?                   @map("success_criteria") @db.Text
  targetDate                  DateTime?                 @map("target_date")
  activatedAt                 DateTime?                 @map("activated_at")
  pausedAt                    DateTime?                 @map("paused_at")
  completedAt                 DateTime?                 @map("completed_at")
  cancelledAt                 DateTime?                 @map("cancelled_at")
  version                     Int                       @default(1)
  createdAt                   DateTime                  @default(now()) @map("created_at")
  updatedAt                   DateTime                  @updatedAt @map("updated_at")
  tenant                      Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  patient                     Patient                   @relation(fields: [patientId], references: [id], onDelete: Restrict)
  createdByNutritionist       Nutritionist              @relation("ClinicalObjectiveCreatedBy", fields: [createdByNutritionistId], references: [id], onDelete: Restrict)
  responsibleNutritionist     Nutritionist              @relation("ClinicalObjectiveResponsible", fields: [responsibleNutritionistId], references: [id], onDelete: Restrict)
  originClinicalEncounter     ClinicalEncounter?        @relation("ClinicalObjectiveOriginEncounter", fields: [originClinicalEncounterId], references: [id], onDelete: Restrict)
  originAnamnesis             Anamnesis?                @relation("ClinicalObjectiveOriginAnamnesis", fields: [originAnamnesisId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, patientId])
  @@index([tenantId, patientId, status])
  @@index([tenantId, status])
  @@index([tenantId, responsibleNutritionistId])
  @@index([tenantId, responsibleNutritionistId, status])
  @@index([tenantId, originClinicalEncounterId])
  @@map("clinical_objectives")
}

enum PatientNutritionistAssignmentStatus {
  ACTIVE
  REMOVED
}

enum PatientNutritionistAssignmentRole {
  PRIMARY
  SUPPORTING
}

model PatientNutritionistAssignment {
  id             String                            @id @default(uuid())
  tenantId       String                            @map("tenant_id")
  patientId      String                            @map("patient_id")
  nutritionistId String                            @map("nutritionist_id")
  role           PatientNutritionistAssignmentRole
  status         PatientNutritionistAssignmentStatus @default(ACTIVE)
  createdAt      DateTime                          @default(now()) @map("created_at")
  reactivatedAt  DateTime?                         @map("reactivated_at")
  removedAt      DateTime?                         @map("removed_at")
  tenant         Tenant                            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  patient        Patient                           @relation(fields: [patientId], references: [id], onDelete: Restrict)
  nutritionist   Nutritionist                      @relation(fields: [nutritionistId], references: [id], onDelete: Restrict)

  @@unique([patientId, nutritionistId])
  @@index([tenantId])
  @@index([patientId])
  @@index([nutritionistId])
  @@index([patientId, status, role])
  @@map("patient_nutritionist_assignments")
}
